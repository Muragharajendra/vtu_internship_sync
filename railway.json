{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile.api"
    },
    "deploy": {
        "startCommand": "bash -c 'uvicorn api.main:app --host 0.0.0.0 --port ${PORT:-8000}'",
        "restartPolicyType": "ON_FAILURE"
    }
}